# Groq AI (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Tavily Web Search (get from https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Financial Modeling Prep (get from https://financialmodelingprep.com)
# Leave blank to run in demo mode
FMP_API_KEY=

# Database (Postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rylo

# Demo mode — uses Black-Scholes mock data, no FMP key needed
DEMO_MODE=true
