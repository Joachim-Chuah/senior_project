# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=sqlite:///./sentiviz.db

# Redis Cache (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_ENABLED=false

# Refresh Intervals (seconds)
OPTIONS_REFRESH_INTERVAL=300

# Black-Scholes
RISK_FREE_RATE=0.045

# Groq AI (get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Tavily Web Search (get from https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here

# Financial Modeling Prep (get from https://financialmodelingprep.com)
FMP_API_KEY=your_fmp_api_key_here
